<?xml version="1.0"?>

<RDF xmlns="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:em="http://www.mozilla.org/2004/em-rdf#">

  <Description about="urn:mozilla:install-manifest">
    <em:id>aeonmoon@palemoon-theme</em:id>
    <em:version>1.1.2</em:version>
    <em:type>4</em:type>

    <em:targetApplication>
      <!-- Pale Moon -->
      <Description>
        <em:id>{8de7fcbb-c55c-4fbe-bfc5-fc555c87dbc4}</em:id>
        <em:minVersion>29.3.0</em:minVersion>
        <em:maxVersion>34.*</em:maxVersion>
      </Description>
    </em:targetApplication>

    <em:name>Aeon Moon</em:name>
    <em:description>Port of the classic Aeon theme by Ed Hume for modern Pale Moon.</em:description>
    <em:creator>Ed Hume</em:creator>
    <em:contributor>Pale Moon port and adaptation: Halvar</em:contributor>
    <em:contributor>Based on SphereGnome, created by Ken S. Lynch.</em:contributor>
    <em:contributor>BlueSphere SVG Icons and others by Vadim Plessky, http://svgicons.sf.net</em:contributor>
    <em:contributor>Additional Tombats font icons by Tom Murphy, http://fonts.tom7.com</em:contributor>

    <em:homepageURL>https://web.archive.org/web/20180730003058/https://addons.mozilla.org/en-US/firefox/addon/aeon/</em:homepageURL>
    <em:license>MPL-1.1</em:license>

    <!-- Kept for theme compatibility with existing skin registrations. -->
    <em:internalName>Aeon</em:internalName>
    <em:skinnable>true</em:skinnable>
  </Description>

</RDF>
